# Shared
NODE_ENV=development
LOG_LEVEL=info

# Database and Redis
DATABASE_URL=postgresql://leadpilot:leadpilot_dev_password@localhost:5432/leadpilot_dev?schema=public
REDIS_URL=redis://localhost:6379

# Public intake organization context. Admin APIs resolve organization from auth.
DEMO_ORGANIZATION_ID=

# API
API_HOST=0.0.0.0
API_PORT=4000
WEB_ORIGIN=http://localhost:3000
SESSION_SECRET=replace_with_at_least_32_random_characters
SESSION_COOKIE_NAME=leadpilot_session
SESSION_TTL_DAYS=7
PUBLIC_RATE_LIMIT_MAX=20
PUBLIC_RATE_LIMIT_WINDOW=1 minute
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW=1 minute

# Web
NEXT_PUBLIC_API_URL=http://localhost:4000

# AI
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Production deployment placeholders
POSTGRES_USER=leadpilot
POSTGRES_PASSWORD=change_me
POSTGRES_DB=leadpilot
CADDY_EMAIL=ops@example.com
