    "fastify": "^5.2.1",
    "ioredis": "^5.4.2",
    "openai": "^4.77.0",
    "pino": "^9.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  }
